# @kurark/ark — core environment contract.
# A consuming app copies the vars it needs into its own root `.env`.
# With NO infra env set, Ark runs the embedded local runtime:
#   PGlite at .ark/<PORT>/database and local uploads at .ark/<PORT>/uploads.

# App port (default 5400). Service ports below default to PORT+1/+2/+3.
PORT=5400

# --- Postgres profile (opt-in) -------------------------------------------------
# Set DATABASE_URL to use Postgres instead of embedded PGlite. The reference
# docker-compose.yml builds a DB from POSTGRES_DB/USER/PASSWORD (default `ark`);
# keep DATABASE_URL in sync with those values.
# DATABASE_URL=postgres://ark:ark@localhost:5401/ark
# POSTGRES_PORT=5401
# POSTGRES_DB=ark
# POSTGRES_USER=ark
# POSTGRES_PASSWORD=ark
# Prefix for compose container/volume names (default `ark`).
# COMPOSE_PROJECT=ark

# --- Auth ----------------------------------------------------------------------
BETTER_AUTH_SECRET=change-before-production
BETTER_AUTH_URL=http://localhost:5400
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:5400,http://127.0.0.1:5400
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=password
ADMIN_NAME=Ark Admin

# --- Email verification (SMTP) -----------------------------------------------
EMAIL_FROM=no-reply@example.com
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=465
EMAIL_SMTP_USER=
EMAIL_SMTP_PASSWORD=
EMAIL_SMTP_SECURE=true

# --- Tenant identity -----------------------------------------------------------
NUXT_PUBLIC_APP_NAME=Ark

# --- Storage (S3-compatible; RustFS locally) ----------------------------------
# Omit entirely to use the embedded local filesystem driver.
RUSTFS_PORT=5402
RUSTFS_CONSOLE_PORT=5403
RUSTFS_ACCESS_KEY=rustfsadmin
RUSTFS_SECRET_KEY=rustfsadmin
STORAGE_LOCATIONS=private,public
STORAGE_PRIVATE_LOCATION=private
STORAGE_PUBLIC_LOCATION=public
STORAGE_AUTO_CREATE_BUCKETS=true
STORAGE_PRIVATE_DRIVER=s3
STORAGE_PRIVATE_BUCKET=ark-files-private
# Optional object namespace inside a shared bucket, for example p3100-my-app/
STORAGE_PRIVATE_PREFIX=
# Production: Yandex Cloud Object Storage, e.g. https://storage.yandexcloud.net
# Local Compose: RustFS at http://localhost:<RUSTFS_PORT>.
STORAGE_PRIVATE_ENDPOINT=http://localhost:5402
STORAGE_PRIVATE_KEY=rustfsadmin
STORAGE_PRIVATE_SECRET=rustfsadmin
STORAGE_PRIVATE_REGION=auto
STORAGE_PRIVATE_FORCE_PATH_STYLE=true
STORAGE_PUBLIC_DRIVER=s3
STORAGE_PUBLIC_BUCKET=ark-files-public
STORAGE_PUBLIC_PREFIX=
STORAGE_PUBLIC_ENDPOINT=http://localhost:5402
STORAGE_PUBLIC_KEY=rustfsadmin
STORAGE_PUBLIC_SECRET=rustfsadmin
STORAGE_PUBLIC_REGION=auto
STORAGE_PUBLIC_FORCE_PATH_STYLE=true
STORAGE_PUBLIC_PUBLIC_URL=
# Embedded local mode (no S3): filesystem driver, defaults to .ark/<PORT>/uploads.
# STORAGE_PRIVATE_DRIVER=local
# STORAGE_PUBLIC_DRIVER=local
# STORAGE_LOCAL_ROOT=
# STORAGE_DEFAULT_LOCATION=private

# --- Signed file URLs ----------------------------------------------------------
# FILES_SIGNED_URL_EXPIRES=300
# FILES_PUBLIC_URL=
# Presigned browser uploads require an S3 storage location. Single PUT is
# intentionally limited to 5 GB by default; tenants may configure a lower cap.
# FILES_UPLOAD_URL_EXPIRES=900
# FILES_DIRECT_UPLOAD_MAX_BYTES=5000000000

# --- Telegram auth + per-user notify (core transport) -------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_OAUTH_CLIENT_ID=
TELEGRAM_OAUTH_CLIENT_SECRET=

# --- Server-side outbound proxy (restricted external APIs) --------------------
# Use a real HTTP/HTTPS/SOCKS proxy endpoint, not a scraper API endpoint.
# Example: http://user:password@ddc.oxylabs.io:8001
OUTBOUND_PROXY_URL=
OUTBOUND_PROXY_HOSTS=api.telegram.org,oauth.telegram.org,openrouter.ai,api.openai.com,api.voyageai.com

# --- Discord auth (core generic OAuth) ----------------------------------------
# OAuth redirect: https://YOUR-DOMAIN/api/auth/oauth2/callback/discord
DISCORD_OAUTH_CLIENT_ID=
DISCORD_OAUTH_CLIENT_SECRET=
