  "name": "@kurark/ark",
  "type": "module",
  "version": "0.1.0-alpha.6",
  "private": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/llll-labs/ark.git"
  },
  "exports": {
    ".": "./nuxt.config.ts",
    "./app/components/core/*": "./app/components/core/*",
    "./db/columns": "./db/columns.ts",
    "./db/schema": "./db/schema.ts",
    "./db/zod": "./db/zod.ts",
    "./server/trpc/routers": "./server/trpc/routers/index.ts",
    "./server/utils/app-settings": "./server/utils/app-settings.ts",
    "./server/utils/app-extensions": "./server/utils/app-extensions.ts",
    "./server/utils/auth": "./server/utils/auth.ts",
    "./server/utils/authorization": "./server/utils/authorization.ts",
    "./server/utils/db": "./server/utils/db.ts",
    "./server/utils/discord-oauth": "./server/utils/discord-oauth.ts",
    "./server/utils/discord-webhook": "./server/utils/discord-webhook.ts",
    "./server/utils/email-otp": "./server/utils/email-otp.ts",
    "./server/utils/market-jobs": "./server/utils/market-jobs.ts",
    "./server/utils/notifications": "./server/utils/notifications.ts",
    "./server/utils/telegram-auth": "./server/utils/telegram-auth.ts",
    "./server/utils/telegram-login": "./server/utils/telegram-login.ts",
    "./server/utils/telegram-mini": "./server/utils/telegram-mini.ts",
    "./server/utils/telegram-oauth": "./server/utils/telegram-oauth.ts"
  },
  "bin": {
    "ark-kill": "scripts/kill-ark.mjs",
    "ark-port-cell": "scripts/with-port-cell.mjs"
  },
  "files": [
    ".env.example",
    "LICENSE",
