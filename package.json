    "better-auth": "^1.6.11",
    "better-call": "1.3.5",
    "drizzle-kit": "0.31.10",
    "drizzle-orm": "0.45.2",
    "drizzle-zod": "^0.8.3",
    "h3": "1.15.11",
    "jose": "^6.2.3",
    "nodemailer": "^9.0.1",
    "nuxt": "4.4.6",
    "pinia": "3.0.4",
    "postgres": "3.4.9",
