    "server/utils/secret.ts",
    "server/utils/storage.ts",
    "server/utils/telegram-auth.ts",
    "server/utils/telegram-login.ts",
    "server/utils/telegram-mini.ts",
    "server/utils/telegram-oauth.ts",
    "server/utils/uuid.ts",
    "tsconfig.json",
    "tsconfig.nuxt.json",
    "types"
  ],
  "scripts": {
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "preflight": "tsx scripts/ark-preflight.ts",
    "stress:seed:gore-ot-uma": "ALLOW_STRESS_SEED=1 tsx scripts/seed-gore-ot-uma.ts",
    "stress:seed:gore-ot-uma:reset": "ALLOW_STRESS_SEED=1 tsx scripts/seed-gore-ot-uma.ts --reset",
    "stress:seed:war-and-peace": "ALLOW_STRESS_SEED=1 tsx scripts/seed-war-and-peace.ts",
    "stress:seed:war-and-peace:reset": "ALLOW_STRESS_SEED=1 tsx scripts/seed-war-and-peace.ts --reset",
    "stress:smoke:chat-history": "tsx scripts/smoke-chat-history.ts",
    "typecheck": "nuxi prepare && vue-tsc --noEmit -p tsconfig.nuxt.json && pnpm run typecheck:scripts",
    "typecheck:scripts": "tsc --ignoreConfig --noEmit --target ES2022 --module ESNext --moduleResolution Bundler --types node --skipLibCheck scripts/*.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1050.0",
    "@aws-sdk/s3-request-presigner": "^3.1050.0",
