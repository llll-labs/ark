    "scripts/kill-ark.mjs",
    "scripts/with-port-cell.mjs",
    "server/api",
    "server/middleware",
    "server/plugins",
    "server/routes",
    "server/trpc",
    "server/utils/app-extensions.ts",
    "server/utils/app-settings.ts",
    "server/utils/auth.ts",
    "server/utils/avatar.ts",
    "server/utils/authorization.ts",
    "server/utils/db.ts",
    "server/utils/discord-oauth.ts",
    "server/utils/discord-webhook.ts",
    "server/utils/email-otp.ts",
    "server/utils/env.ts",
    "server/utils/file-paths.ts",
